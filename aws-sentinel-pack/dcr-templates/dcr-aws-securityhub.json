{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "dataCollectionRuleName": {
      "type": "string",
      "defaultValue": "dcr-AWSSecurityHubFindings-aws",
      "metadata": {
        "description": "Name of the Data Collection Rule. Must be unique within the resource group."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region. Must match the region of the Log Analytics workspace."
      }
    },
    "workspaceResourceId": {
      "type": "string",
      "metadata": {
        "description": "Full resource ID of the Log Analytics workspace, e.g. /subscriptions/{subId}/resourceGroups/{rg}/providers/Microsoft.OperationalInsights/workspaces/{name}"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Insights/dataCollectionRules",
      "apiVersion": "2023-03-11",
      "name": "[parameters('dataCollectionRuleName')]",
      "location": "[parameters('location')]",
      "kind": "Direct",
      "properties": {
        "description": "DCR for ingesting AWS Security Hub findings into the native AWSSecurityHubFindings Microsoft Sentinel table via the Logs Ingestion API. Deployed by aws-sentinel-packv3.",
        "streamDeclarations": {
          "Custom-AWSSecurityHubFindings": {
            "columns": [
              { "name": "TimeGenerated",                          "type": "datetime" },
              { "name": "AwsAccountId",                           "type": "string"   },
              { "name": "AwsRegion",                              "type": "string"   },
              { "name": "AwsSecurityFindingCreatedAt",            "type": "datetime" },
              { "name": "AwsSecurityFindingDescription",          "type": "string"   },
              { "name": "AwsSecurityFindingFirstObservedAt",      "type": "datetime" },
              { "name": "AwsSecurityFindingGeneratorId",          "type": "string"   },
              { "name": "AwsSecurityFindingId",                   "type": "string"   },
              { "name": "AwsSecurityFindingLastObservedAt",       "type": "datetime" },
              { "name": "AwsSecurityFindingProcessedAt",          "type": "datetime" },
              { "name": "AwsSecurityFindingProductArn",           "type": "string"   },
              { "name": "AwsSecurityFindingProductFields",        "type": "string"   },
              { "name": "AwsSecurityFindingProductName",          "type": "string"   },
              { "name": "AwsSecurityFindingSeverity",             "type": "string"   },
              { "name": "AwsSecurityFindingTitle",                "type": "string"   },
              { "name": "AwsSecurityFindingTypes",                "type": "string"   },
              { "name": "AwsSecurityFindingUpdatedAt",            "type": "datetime" },
              { "name": "ComplianceAssociatedStandards",          "type": "string"   },
              { "name": "ComplianceRelatedRequirements",          "type": "string"   },
              { "name": "ComplianceSecurityControlId",            "type": "string"   },
              { "name": "ComplianceSecurityControlParameters",    "type": "string"   },
              { "name": "ComplianceStatus",                       "type": "string"   },
              { "name": "ComplianceStatusReasons",                "type": "string"   },
              { "name": "RawData",                                "type": "string"   },
              { "name": "RecordState",                            "type": "string"   },
              { "name": "Remediation",                            "type": "string"   },
              { "name": "Resources",                              "type": "string"   },
              { "name": "SchemaVersion",                          "type": "string"   },
              { "name": "WorkflowState",                          "type": "string"   }
            ]
          }
        },
        "destinations": {
          "logAnalytics": [
            {
              "workspaceResourceId": "[parameters('workspaceResourceId')]",
              "name": "sentinel-workspace"
            }
          ]
        },
        "dataFlows": [
          {
            "streams": [
              "Custom-AWSSecurityHubFindings"
            ],
            "destinations": [
              "sentinel-workspace"
            ],
            "outputStream": "Microsoft-AWSSecurityHubFindings",
            "transformKql": "source"
          }
        ]
      }
    }
  ],
  "outputs": {
    "dataCollectionRuleId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))]"
    },
    "immutableId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))).immutableId]"
    },
    "logsIngestionEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))).logsIngestion.endpoint]"
    },
    "criblDestinationUrl": {
      "type": "string",
      "value": "[concat(reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))).logsIngestion.endpoint, '/dataCollectionRules/', reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))).immutableId, '/streams/Custom-AWSSecurityHubFindings?api-version=2023-01-01')]"
    }
  }
}
