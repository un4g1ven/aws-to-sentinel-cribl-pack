{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "dataCollectionRuleName": {
      "type": "string",
      "defaultValue": "dcr-AWSGuardDuty-aws",
      "metadata": {
        "description": "Name of the Data Collection Rule. Must be unique within the resource group."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region. Must match the region of the Log Analytics workspace."
      }
    },
    "workspaceResourceId": {
      "type": "string",
      "metadata": {
        "description": "Full resource ID of the Log Analytics workspace, e.g. /subscriptions/{subId}/resourceGroups/{rg}/providers/Microsoft.OperationalInsights/workspaces/{name}"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Insights/dataCollectionRules",
      "apiVersion": "2023-03-11",
      "name": "[parameters('dataCollectionRuleName')]",
      "location": "[parameters('location')]",
      "kind": "Direct",
      "properties": {
        "description": "DCR for ingesting AWS GuardDuty findings into the native AWSGuardDuty Microsoft Sentinel table via the Logs Ingestion API. Deployed by aws-sentinel-packv3.",
        "streamDeclarations": {
          "Custom-AWSGuardDuty": {
            "columns": [
              { "name": "TimeGenerated",   "type": "datetime" },
              { "name": "AccountId",       "type": "string"   },
              { "name": "ActivityType",    "type": "string"   },
              { "name": "Arn",             "type": "string"   },
              { "name": "Description",     "type": "string"   },
              { "name": "Id",              "type": "string"   },
              { "name": "Partition",       "type": "string"   },
              { "name": "Region",          "type": "string"   },
              { "name": "ResourceDetails", "type": "string"   },
              { "name": "SchemaVersion",   "type": "string"   },
              { "name": "ServiceDetails",  "type": "string"   },
              { "name": "Severity",        "type": "real"     },
              { "name": "TimeCreated",     "type": "datetime" },
              { "name": "Title",           "type": "string"   },
              { "name": "Type",            "type": "string"   }
            ]
          }
        },
        "destinations": {
          "logAnalytics": [
            {
              "workspaceResourceId": "[parameters('workspaceResourceId')]",
              "name": "sentinel-workspace"
            }
          ]
        },
        "dataFlows": [
          {
            "streams": [
              "Custom-AWSGuardDuty"
            ],
            "destinations": [
              "sentinel-workspace"
            ],
            "outputStream": "Microsoft-AWSGuardDuty",
            "transformKql": "source"
          }
        ]
      }
    }
  ],
  "outputs": {
    "dataCollectionRuleId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))]"
    },
    "immutableId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))).immutableId]"
    },
    "logsIngestionEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))).logsIngestion.endpoint]"
    },
    "criblDestinationUrl": {
      "type": "string",
      "value": "[concat(reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))).logsIngestion.endpoint, '/dataCollectionRules/', reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))).immutableId, '/streams/Custom-AWSGuardDuty?api-version=2023-01-01')]"
    }
  }
}
