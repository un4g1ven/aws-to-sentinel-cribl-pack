{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "dataCollectionRuleName": {
      "type": "string",
      "defaultValue": "dcr-AWSNLBAccessLogs-aws",
      "metadata": {
        "description": "Name of the Data Collection Rule. Must be unique within the resource group."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region. Must match the region of the Log Analytics workspace."
      }
    },
    "workspaceResourceId": {
      "type": "string",
      "metadata": {
        "description": "Full resource ID of the Log Analytics workspace, e.g. /subscriptions/{subId}/resourceGroups/{rg}/providers/Microsoft.OperationalInsights/workspaces/{name}"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Insights/dataCollectionRules",
      "apiVersion": "2023-03-11",
      "name": "[parameters('dataCollectionRuleName')]",
      "location": "[parameters('location')]",
      "kind": "Direct",
      "properties": {
        "description": "DCR for ingesting AWS NLB Access Logs into the native AWSNLBAccessLogs Microsoft Sentinel table via the Logs Ingestion API. Deployed by aws-sentinel-packv3.",
        "streamDeclarations": {
          "Custom-AWSNLBAccessLogs": {
            "columns": [
              { "name": "TimeGenerated",            "type": "datetime" },
              { "name": "NLBType",                  "type": "string"   },
              { "name": "Version",                  "type": "string"   },
              { "name": "Nlb",                      "type": "string"   },
              { "name": "Listener",                 "type": "string"   },
              { "name": "ClientIPPort",             "type": "string"   },
              { "name": "TargetIPPort",             "type": "string"   },
              { "name": "ConnectionTime",           "type": "string"   },
              { "name": "TlsHandshakeTime",         "type": "string"   },
              { "name": "ReceivedBytes",            "type": "long"     },
              { "name": "SentBytes",                "type": "long"     },
              { "name": "IncomingTLSAlert",         "type": "string"   },
              { "name": "ChosenCertArn",            "type": "string"   },
              { "name": "ChosenCertSerial",         "type": "string"   },
              { "name": "TLSCipher",                "type": "string"   },
              { "name": "TLSProtocolVersion",       "type": "string"   },
              { "name": "TLSNamedGroup",            "type": "string"   },
              { "name": "DomainName",               "type": "string"   },
              { "name": "ALPNFEProtocol",           "type": "string"   },
              { "name": "ALPNBEProtocol",           "type": "string"   },
              { "name": "ALPNClientPrefList",       "type": "string"   },
              { "name": "TLSConnectionCreationTime","type": "string"   }
            ]
          }
        },
        "destinations": {
          "logAnalytics": [
            {
              "workspaceResourceId": "[parameters('workspaceResourceId')]",
              "name": "sentinel-workspace"
            }
          ]
        },
        "dataFlows": [
          {
            "streams": [
              "Custom-AWSNLBAccessLogs"
            ],
            "destinations": [
              "sentinel-workspace"
            ],
            "outputStream": "Microsoft-AWSNLBAccessLogs",
            "transformKql": "source"
          }
        ]
      }
    }
  ],
  "outputs": {
    "dataCollectionRuleId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))]"
    },
    "immutableId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))).immutableId]"
    },
    "logsIngestionEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))).logsIngestion.endpoint]"
    },
    "criblDestinationUrl": {
      "type": "string",
      "value": "[concat(reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))).logsIngestion.endpoint, '/dataCollectionRules/', reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))).immutableId, '/streams/Custom-AWSNLBAccessLogs?api-version=2023-01-01')]"
    }
  }
}
