{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "workspaceResourceId": {
      "type": "string",
      "metadata": {
        "description": "The resource ID of the Log Analytics workspace where AWSNLBAccessLogs data will be sent."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the Data Collection Rule."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Insights/dataCollectionRules",
      "apiVersion": "2021-09-01-preview",
      "name": "dcr-aws-nlb",
      "location": "[parameters('location')]",
      "kind": "Direct",
      "properties": {
        "streamDeclarations": {
          "Custom-AWSNLBAccessLogsStream": {
            "columns": [
              { "name": "TimeGenerated", "type": "datetime" },
              { "name": "NLBType", "type": "string" },
              { "name": "Version", "type": "string" },
              { "name": "Nlb", "type": "string" },
              { "name": "Listener", "type": "string" },
              { "name": "ClientIPPort", "type": "string" },
              { "name": "TeruetIPPort", "type": "string" },
              { "name": "ConnectionTime", "type": "string" },
              { "name": "TlsHandshakeTime", "type": "string" },
              { "name": "ReceivedBytes", "type": "string" },
              { "name": "SentBytes", "type": "string" },
              { "name": "IncomingTLSAlert", "type": "string" },
              { "name": "ChosenCertArn", "type": "string" },
              { "name": "ChosenCertSerial", "type": "string" },
              { "name": "TLSCipher", "type": "string" },
              { "name": "TLSProtocolVersion", "type": "string" },
              { "name": "TLSNamedGroup", "type": "string" },
              { "name": "DomainName", "type": "string" },
              { "name": "ALPNFEProtocol", "type": "string" },
              { "name": "ALPNBEProtocol", "type": "string" },
              { "name": "ALPNClientPrefList", "type": "string" },
              { "name": "TLSConnectionCreationTime", "type": "string" }
            ]
          }
        },
        "destinations": {
          "logAnalytics": [
            {
              "workspaceResourceId": "[parameters('workspaceResourceId')]",
              "name": "sentinel-workspace"
            }
          ]
        },
        "dataFlows": [
          {
            "streams": ["Custom-AWSNLBAccessLogsStream"],
            "destinations": ["sentinel-workspace"],
            "outputStream": "Microsoft-AWSNLBAccessLogs",
            "transformKql": "source"
          }
        ]
      }
    }
  ],
  "outputs": {
    "dcrId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/dataCollectionRules', 'dcr-aws-nlb')]"
    },
    "dcrImmutableId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', 'dcr-aws-nlb')).immutableId]"
    }
  }
}
