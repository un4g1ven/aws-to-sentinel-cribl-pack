{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "dataCollectionRuleName": {
      "type": "string",
      "defaultValue": "dcr-AWSCloudTrail-aws",
      "metadata": {
        "description": "Name of the Data Collection Rule. Must be unique within the resource group."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region. Must match the region of the Log Analytics workspace."
      }
    },
    "workspaceResourceId": {
      "type": "string",
      "metadata": {
        "description": "Full resource ID of the Log Analytics workspace, e.g. /subscriptions/{subId}/resourceGroups/{rg}/providers/Microsoft.OperationalInsights/workspaces/{name}"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Insights/dataCollectionRules",
      "apiVersion": "2023-03-11",
      "name": "[parameters('dataCollectionRuleName')]",
      "location": "[parameters('location')]",
      "kind": "Direct",
      "properties": {
        "description": "DCR for ingesting AWS CloudTrail logs into the native AWSCloudTrail Microsoft Sentinel table via the Logs Ingestion API (no DCE required). Deployed by aws-sentinel-packv3.",
        "streamDeclarations": {
          "Custom-AWSCloudTrail": {
            "columns": [
              { "name": "TimeGenerated",              "type": "datetime"  },
              { "name": "AwsEventId",                 "type": "string"    },
              { "name": "EventName",                   "type": "string"    },
              { "name": "EventSource",                 "type": "string"    },
              { "name": "EventTypeName",               "type": "string"    },
              { "name": "EventVersion",                "type": "string"    },
              { "name": "AWSRegion",                   "type": "string"    },
              { "name": "AwsRequestId",                "type": "string"    },
              { "name": "AwsRequestId_",               "type": "string"    },
              { "name": "Category",                    "type": "string"    },
              { "name": "OperationName",               "type": "string"    },
              { "name": "SourceIpAddress",             "type": "string"    },
              { "name": "UserAgent",                   "type": "string"    },
              { "name": "ErrorCode",                   "type": "string"    },
              { "name": "ErrorMessage",                "type": "string"    },
              { "name": "ManagementEvent",             "type": "boolean"   },
              { "name": "ReadOnly",                    "type": "boolean"   },
              { "name": "APIVersion",                  "type": "string"    },
              { "name": "RecipientAccountId",          "type": "string"    },
              { "name": "SharedEventId",               "type": "string"    },
              { "name": "VpcEndpointId",               "type": "string"    },
              { "name": "EC2RoleDelivery",             "type": "string"    },
              { "name": "RequestParameters",           "type": "string"    },
              { "name": "ResponseElements",            "type": "string"    },
              { "name": "AdditionalEventData",         "type": "string"    },
              { "name": "Resources",                   "type": "string"    },
              { "name": "ServiceEventDetails",         "type": "string"    },
              { "name": "UserIdentityType",            "type": "string"    },
              { "name": "UserIdentityPrincipalid",     "type": "string"    },
              { "name": "UserIdentityArn",             "type": "string"    },
              { "name": "UserIdentityAccountId",       "type": "string"    },
              { "name": "UserIdentityAccessKeyId",     "type": "string"    },
              { "name": "UserIdentityUserName",        "type": "string"    },
              { "name": "UserIdentityInvokedBy",       "type": "string"    },
              { "name": "UserIdentityUserId",          "type": "string"    },
              { "name": "UserIdentityStoreArn",        "type": "string"    },
              { "name": "SessionMfaAuthenticated",     "type": "boolean"   },
              { "name": "SessionCreationDate",         "type": "datetime"  },
              { "name": "SessionIssuerType",           "type": "string"    },
              { "name": "SessionIssuerPrincipalId",    "type": "string"    },
              { "name": "SessionIssuerArn",            "type": "string"    },
              { "name": "SessionIssuerAccountId",      "type": "string"    },
              { "name": "SessionIssuerUserName",       "type": "string"    },
              { "name": "TlsVersion",                  "type": "string"    },
              { "name": "CipherSuite",                 "type": "string"    },
              { "name": "ClientProvidedHostHeader",    "type": "string"    },
              { "name": "CidrIp",                      "type": "string"    },
              { "name": "DestinationPort",             "type": "string"    },
              { "name": "IpProtocol",                  "type": "string"    },
              { "name": "SourcePort",                  "type": "string"    }
            ]
          }
        },
        "destinations": {
          "logAnalytics": [
            {
              "workspaceResourceId": "[parameters('workspaceResourceId')]",
              "name": "sentinel-workspace"
            }
          ]
        },
        "dataFlows": [
          {
            "streams": [
              "Custom-AWSCloudTrail"
            ],
            "destinations": [
              "sentinel-workspace"
            ],
            "outputStream": "Microsoft-AWSCloudTrail",
            "transformKql": "source"
          }
        ]
      }
    }
  ],
  "outputs": {
    "dataCollectionRuleId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))]"
    },
    "immutableId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))).immutableId]"
    },
    "logsIngestionEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))).logsIngestion.endpoint]"
    },
    "criblDestinationUrl": {
      "type": "string",
      "value": "[concat(reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))).logsIngestion.endpoint, '/dataCollectionRules/', reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))).immutableId, '/streams/Custom-AWSCloudTrail?api-version=2023-01-01')]"
    }
  }
}
