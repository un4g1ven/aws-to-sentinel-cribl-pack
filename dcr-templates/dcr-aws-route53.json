{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "dataCollectionRuleName": {
      "type": "string",
      "defaultValue": "dcr-AWSRoute53Resolver-aws",
      "metadata": {
        "description": "Name of the Data Collection Rule. Must be unique within the resource group."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region. Must match the region of the Log Analytics workspace."
      }
    },
    "workspaceResourceId": {
      "type": "string",
      "metadata": {
        "description": "Full resource ID of the Log Analytics workspace, e.g. /subscriptions/{subId}/resourceGroups/{rg}/providers/Microsoft.OperationalInsights/workspaces/{name}"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Insights/dataCollectionRules",
      "apiVersion": "2023-03-11",
      "name": "[parameters('dataCollectionRuleName')]",
      "location": "[parameters('location')]",
      "kind": "Direct",
      "properties": {
        "description": "DCR for ingesting AWS Route53 Resolver query logs into the native AWSRoute53Resolver Microsoft Sentinel table via the Logs Ingestion API. Deployed by aws-sentinel-packv3.",
        "streamDeclarations": {
          "Custom-AWSRoute53Resolver": {
            "columns": [
              { "name": "TimeGenerated",          "type": "datetime" },
              { "name": "AccountId",              "type": "string"   },
              { "name": "Answers",               "type": "string"   },
              { "name": "FirewallDomainListId",   "type": "string"   },
              { "name": "FirewallRuleAction",     "type": "string"   },
              { "name": "FirewallRuleGroupId",    "type": "string"   },
              { "name": "LogType",                "type": "string"   },
              { "name": "QueryClass",             "type": "string"   },
              { "name": "QueryName",              "type": "string"   },
              { "name": "QueryType",              "type": "string"   },
              { "name": "Rcode",                  "type": "string"   },
              { "name": "Region",                 "type": "string"   },
              { "name": "SrcAddr",                "type": "string"   },
              { "name": "SrcIds",                 "type": "string"   },
              { "name": "SrcPort",                "type": "string"   },
              { "name": "Transport",              "type": "string"   },
              { "name": "Version",                "type": "string"   },
              { "name": "VpcId",                  "type": "string"   }
            ]
          }
        },
        "destinations": {
          "logAnalytics": [
            {
              "workspaceResourceId": "[parameters('workspaceResourceId')]",
              "name": "sentinel-workspace"
            }
          ]
        },
        "dataFlows": [
          {
            "streams": [
              "Custom-AWSRoute53Resolver"
            ],
            "destinations": [
              "sentinel-workspace"
            ],
            "outputStream": "Microsoft-AWSRoute53Resolver",
            "transformKql": "source"
          }
        ]
      }
    }
  ],
  "outputs": {
    "dataCollectionRuleId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))]"
    },
    "immutableId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))).immutableId]"
    },
    "logsIngestionEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))).logsIngestion.endpoint]"
    },
    "criblDestinationUrl": {
      "type": "string",
      "value": "[concat(reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))).logsIngestion.endpoint, '/dataCollectionRules/', reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))).immutableId, '/streams/Custom-AWSRoute53Resolver?api-version=2023-01-01')]"
    }
  }
}
