{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "dataCollectionRuleName": {
      "type": "string",
      "defaultValue": "dcr-aws-waf",
      "metadata": {
        "description": "Name of the Data Collection Rule for AWS WAF logs."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the DCR resource."
      }
    },
    "workspaceResourceId": {
      "type": "string",
      "metadata": {
        "description": "Full ARM resource ID of the Log Analytics workspace backing Microsoft Sentinel."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Insights/dataCollectionRules",
      "apiVersion": "2021-09-01-preview",
      "name": "[parameters('dataCollectionRuleName')]",
      "location": "[parameters('location')]",
      "kind": "Direct",
      "properties": {
        "streamDeclarations": {
          "Custom-AWSWAFStream": {
            "columns": [
              { "name": "Action",                       "type": "string"   },
              { "name": "Args",                         "type": "string"   },
              { "name": "CaptchaResponse",              "type": "dynamic"  },
              { "name": "ChallengeResponse",            "type": "dynamic"  },
              { "name": "ClientIp",                     "type": "string"   },
              { "name": "Country",                      "type": "string"   },
              { "name": "ExcludedRules",                "type": "dynamic"  },
              { "name": "FormatVersion",                "type": "string"   },
              { "name": "Headers",                      "type": "dynamic"  },
              { "name": "HttpMethod",                   "type": "string"   },
              { "name": "HttpRequest",                  "type": "dynamic"  },
              { "name": "HttpSourceId",                 "type": "string"   },
              { "name": "HttpSourceName",               "type": "string"   },
              { "name": "HttpVersion",                  "type": "string"   },
              { "name": "Ja3Fingerprint",               "type": "string"   },
              { "name": "Labels",                       "type": "dynamic"  },
              { "name": "NonTerminatingMatchingRules",  "type": "dynamic"  },
              { "name": "OversizeFields",               "type": "dynamic"  },
              { "name": "RateBasedRuleList",            "type": "dynamic"  },
              { "name": "RequestHeadersInserted",       "type": "dynamic"  },
              { "name": "RequestId",                    "type": "string"   },
              { "name": "ResponseCodeSent",             "type": "int"      },
              { "name": "RuleGroupId",                  "type": "string"   },
              { "name": "RuleGroupList",                "type": "dynamic"  },
              { "name": "TerminatingRule",              "type": "dynamic"  },
              { "name": "TerminatingRuleId",            "type": "string"   },
              { "name": "TerminatingRuleMatchDetails",  "type": "dynamic"  },
              { "name": "TerminatingRuleType",          "type": "string"   },
              { "name": "TimeGenerated",                "type": "datetime" },
              { "name": "Uri",                          "type": "string"   },
              { "name": "WebAclId",                     "type": "string"   }
            ]
          }
        },
        "destinations": {
          "logAnalytics": [
            {
              "workspaceResourceId": "[parameters('workspaceResourceId')]",
              "name": "sentinel-workspace"
            }
          ]
        },
        "dataFlows": [
          {
            "streams": [ "Custom-AWSWAFStream" ],
            "destinations": [ "sentinel-workspace" ],
            "outputStream": "Microsoft-AWSWAF",
            "transformKql": "source"
          }
        ]
      }
    }
  ],
  "outputs": {
    "dataCollectionRuleId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))]"
    },
    "immutableId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))).immutableId]"
    },
    "streamName": {
      "type": "string",
      "value": "Custom-AWSWAFStream"
    }
  }
}
